# Delta Exchange India API Credentials
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# Set to "true" for testnet, "false" for production
DELTA_TESTNET=true

# Optional: Telegram Bot Token for alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App secret key for encrypting stored credentials
APP_SECRET_KEY=change-this-to-a-random-string
